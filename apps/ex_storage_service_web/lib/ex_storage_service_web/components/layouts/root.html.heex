<!DOCTYPE html>
<html lang="en" data-theme="sunshine">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Plug.CSRFProtection.get_csrf_token()} />
    <.live_title default="ExStorageService">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" type="image/x-icon" href={~p"/favicon.ico"} />
    <link rel="shortcut icon" type="image/x-icon" href={~p"/favicon.ico"} />
    <link
      phx-track-static
      rel="stylesheet"
      href={
        DuskmoonBundler.static_path(ExStorageServiceWeb.Endpoint, "/assets/css/app.css",
          outdir: "priv/static/assets"
        )
      }
    />
    <script
      defer
      phx-track-static
      type="module"
      src={
        DuskmoonBundler.static_path(ExStorageServiceWeb.Endpoint, "/assets/js/app.js",
          outdir: "priv/static/assets"
        )
      }
    >
    </script>
  </head>
  <body class="bg-surface text-on-surface min-h-screen">
    {@inner_content}
  </body>
</html>
